<html>
  <head>
    <meta charset="UTF-8">
    <!--<script src="https://aframe.io/releases/1.7.1/aframe.min.js"></script>-->
    <script src="../aframe/aframe.min.js"></script>
  </head>
  <body>
    <a-scene stats>

      <a-assets>
        <img id="nebo" src="../images/nebo.jpg">
        <img id="caravaggio" src="https://raw.githubusercontent.com/aframevr/sample-assets/master/assets/images/illustration/758px-Canestra_di_frutta_(Caravaggio).jpg">
        <a-asset-item id="models" src="../models/cat.glb"></a-asset-item>
      </a-assets>

      <a-sky src="#nebo" color="#87CEFA"></a-nebo>
      <a-torus position="1 1 -2" color="green" radius="1.2"
      animation = "property: components.material.material.color; type: color; from: green; to: red; loop: true; dur: 10000"
      ></a-torus>
      <a-plane src = "#caravaggio" width="7" height="7" rotation="-50 0 0" position="-2 -2 -5" color="purple"></a-plane>
      <a-cylinder color="yellow" height="2" radius="0.05" position="-2 -1 -5"></a-cylinder>
      <a-cylinder color="blue" height="2" radius="0.05" position="-3 -1 -5"></a-cylinder>
      <a-torus-knot color="orange" radius="1.2" position="-3 1 -5"
      animation = "property:rotation; to: 0 0 360; loop: true; dur: 10000"  ></a-torus-knot>

      <a-entity position="1 3 -5" animation = "property:rotation; to: 180 360 90; loop: true; dur: 2000">
        <a-sphere radius = "1" src = "../images/nebo.jpg"></a-sphere>
        <a-cylinder color="yellow" height="3" radius="0.05" ></a-cylinder>
      </a-entity>

      <a-plane width="9" height="2" position="3 1 -9"></a-plane>
      <a-text value="Вітаємо у браузерній VR!" font="../fonts/yahei-msdf.json" negate="false"
              color="blue" width="10" position="-0.5 1 -6"></a-text>
      <a-text value="Борщ Дмитро" font="../fonts/yahei-msdf.json" negate="false"
              color="pink" width="10" position="-0.5 1.5 -6"
              animation = "property:position; to: -0.5 1.5 6; loop: true; dur: 15000" ></a-text>
      
      <a-entity position="2.5 -1 -4"  scale="1 1 1" rotation = "0 -90 0" gltf-model="#models"
        animation = "property:scale; delay: 7000; to: 4 4 4; loop: true; dur: 30000">
      </a-entity>

      
    </a-scene>
  </body>
</html>
